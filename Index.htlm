<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Tech Officiel - Toutes les solutions premium réunies. Fast Food, Streaming, Musique, Cartes.">
<title>Tech Officiel — Toutes les solutions premium réunies</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Rajdhani:wght@400;500;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --black:#020408;--dark:#070d14;
  --blue:#00aaff;--cyan:#00fff7;--violet:#7b2fff;--pink:#ff2d78;--green:#00ff88;--gold:#ffd700;
  --white:#fff;--text:#b8cce0;
  --gb:0 0 20px rgba(0,170,255,.6),0 0 60px rgba(0,170,255,.3);
  --fd:'Orbitron',sans-serif;--fh:'Rajdhani',sans-serif;--fb:'Inter',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--black);color:var(--text);font-family:var(--fb);overflow-x:hidden}
a{text-decoration:none;color:inherit}ul{list-style:none}

/* LOADER */
#loader{position:fixed;inset:0;background:var(--black);z-index:9999;display:flex;flex-direction:column;align-items:center;justify-content:center;transition:opacity .7s ease,visibility .7s ease}
#loader.hidden{opacity:0;visibility:hidden;pointer-events:none}
.ll{font-family:var(--fd);font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;color:#fff;letter-spacing:.08em;margin-bottom:2rem;animation:pglow 1.5s ease-in-out infinite}
.ll span{color:var(--blue)}
.lb{width:220px;height:3px;background:rgba(255,255,255,.08);border-radius:2px;overflow:hidden;margin-bottom:1rem}
.lbf{height:100%;background:linear-gradient(90deg,var(--blue),var(--cyan),var(--violet));animation:lf 2.2s ease forwards}
.lt{font-family:var(--fh);font-size:.75rem;letter-spacing:.3em;color:var(--blue);text-transform:uppercase;animation:bl 1s step-end infinite}
@keyframes lf{from{width:0}to{width:100%}}
@keyframes bl{50%{opacity:0}}
@keyframes pglow{0%,100%{text-shadow:0 0 20px rgba(0,170,255,.8),0 0 40px rgba(0,170,255,.4)}50%{text-shadow:0 0 40px rgba(0,170,255,1),0 0 80px rgba(0,170,255,.6)}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes flt{0%,100%{transform:translateY(0)}50%{transform:translateY(-12px)}}
@keyframes pls{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(.8)}}

/* PARTICLES */
#pc{position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:0;opacity:.35}

/* REVEAL */
.rv{opacity:0;transform:translateY(35px);transition:opacity .7s ease,transform .7s ease}
.rv.vis{opacity:1;transform:translateY(0)}

/* NAV */
#nav{position:fixed;top:0;left:0;right:0;z-index:1000;padding:0 2rem;height:70px;display:flex;align-items:center;justify-content:space-between;background:rgba(2,4,8,.85);backdrop-filter:blur(20px);border-bottom:1px solid rgba(0,170,255,.12);transition:all .3s ease}
#nav.sc{height:60px;background:rgba(2,4,8,.97);border-bottom-color:rgba(0,170,255,.28)}
.nl{display:flex;align-items:center;gap:.5rem}
.ni{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--violet));display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-weight:900;font-size:.85rem;color:#fff;box-shadow:var(--gb);border:2px solid rgba(0,170,255,.35);flex-shrink:0;transition:transform .3s ease}
.ni:hover{transform:rotate(10deg) scale(1.1)}
.nt{font-family:var(--fd);font-size:.95rem;font-weight:700;color:#fff;line-height:1.2}
.nt span{color:var(--blue)}
.ns{font-family:var(--fh);font-size:.6rem;color:var(--text);letter-spacing:.15em;text-transform:uppercase}
.nlinks{display:flex;align-items:center;gap:.2rem}
.nlinks a{font-family:var(--fh);font-size:.82rem;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:var(--text);padding:.4rem .7rem;border-radius:6px;transition:all .2s ease;position:relative}
.nlinks a::after{content:'';position:absolute;bottom:0;left:50%;right:50%;height:2px;background:var(--blue);transition:all .3s ease;border-radius:1px}
.nlinks a:hover{color:var(--blue)}.nlinks a:hover::after{left:10%;right:10%}
.ncta{background:linear-gradient(135deg,var(--blue),var(--violet));color:#fff!important;padding:.5rem 1.2rem!important;border-radius:8px!important;box-shadow:var(--gb);transition:all .3s ease!important}
.ncta:hover{transform:translateY(-2px)}.ncta::after{display:none!important}
.brg{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:5px}
.brg span{display:block;width:26px;height:2px;background:var(--blue);border-radius:2px;transition:all .3s ease;box-shadow:0 0 8px rgba(0,170,255,.6)}
.brg.open span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.brg.open span:nth-child(2){opacity:0;transform:scaleX(0)}
.brg.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
#mm{position:fixed;top:70px;left:0;right:0;background:rgba(2,4,8,.98);backdrop-filter:blur(30px);border-bottom:1px solid rgba(0,170,255,.18);padding:1.25rem 1.5rem;z-index:999;transform:translateY(-110%);opacity:0;visibility:hidden;transition:all .4s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;gap:.2rem}
#mm.open{transform:translateY(0);opacity:1;visibility:visible}
#mm a{font-family:var(--fh);font-size:1.05rem;font-weight:600;letter-spacing:.05em;text-transform:uppercase;color:var(--text);padding:.8rem 1rem;border-radius:8px;border:1px solid transparent;transition:all .2s ease}
#mm a:hover{color:var(--blue);border-color:rgba(0,170,255,.2);background:rgba(0,170,255,.05)}
.mc{margin-top:.5rem;background:linear-gradient(135deg,var(--blue),var(--violet))!important;color:#fff!important;text-align:center;box-shadow:var(--gb)}

/* HERO */
#hero{min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden;padding:100px 2rem 4rem}
.hbg{position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 60% 50%,rgba(0,100,255,.12) 0%,transparent 70%),radial-gradient(ellipse 50% 40% at 80% 80%,rgba(123,47,255,.08) 0%,transparent 60%),radial-gradient(ellipse 40% 30% at 20% 20%,rgba(0,255,247,.06) 0%,transparent 60%),var(--black)}
.hgr{position:absolute;inset:0;background-image:linear-gradient(rgba(0,170,255,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,170,255,.04) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse 80% 80% at 50% 50%,black 30%,transparent 100%)}
.hi{max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center;position:relative;z-index:2;width:100%}
.hl{display:flex;flex-direction:column;gap:1.5rem}
.hbdg{display:inline-flex;align-items:center;gap:.5rem;background:rgba(0,170,255,.08);border:1px solid rgba(0,170,255,.25);border-radius:100px;padding:.4rem 1rem;width:fit-content;font-family:var(--fh);font-size:.8rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--blue)}
.hbdg::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--cyan);box-shadow:0 0 10px var(--cyan);animation:pls 2s ease-in-out infinite}
.htit{font-family:var(--fd);font-size:clamp(1.8rem,4vw,3.5rem);font-weight:900;line-height:1.1;color:#fff;letter-spacing:-.02em}
.gt{background:linear-gradient(135deg,var(--blue) 0%,var(--cyan) 40%,var(--violet) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hsub{font-family:var(--fh);font-size:1.1rem;color:var(--text);letter-spacing:.05em}
.hsub span{color:var(--blue);font-weight:600}
.hst{display:grid;grid-template-columns:repeat(4,1fr);gap:.6rem;padding:.9rem;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:12px}
.hsi{display:flex;flex-direction:column;align-items:center;gap:.2rem;padding:.4rem 0;border-right:1px solid rgba(255,255,255,.06)}
.hsi:last-child{border-right:none}
.hsi-i{font-size:1.1rem}.hsi-l{font-family:var(--fh);font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);font-weight:700}
.hsi-d{font-size:.6rem;color:rgba(184,204,224,.6);text-align:center}
.hbts{display:flex;gap:1rem;flex-wrap:wrap}
.bp{display:inline-flex;align-items:center;gap:.6rem;background:linear-gradient(135deg,var(--blue),#0066cc);color:#fff;font-family:var(--fh);font-weight:700;font-size:.9rem;letter-spacing:.08em;text-transform:uppercase;padding:.85rem 1.8rem;border-radius:10px;border:none;cursor:pointer;box-shadow:var(--gb);transition:all .3s ease;position:relative;overflow:hidden}
.bp::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.15),transparent);transition:left .5s ease}
.bp:hover::before{left:100%}.bp:hover{transform:translateY(-3px);box-shadow:0 10px 40px rgba(0,170,255,.5)}
.bt{display:inline-flex;align-items:center;gap:.6rem;background:rgba(0,136,204,.12);color:var(--blue);font-family:var(--fh);font-weight:700;font-size:.9rem;letter-spacing:.08em;text-transform:uppercase;padding:.85rem 1.8rem;border-radius:10px;border:1px solid rgba(0,170,255,.35);cursor:pointer;transition:all .3s ease}
.bt:hover{background:rgba(0,136,204,.25);border-color:var(--blue);box-shadow:var(--gb);transform:translateY(-3px)}
.hbr{display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap}
.bl2{font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(184,204,224,.5);white-space:nowrap}
.bic{display:flex;gap:.7rem;align-items:center;flex-wrap:wrap}
.bic div{width:36px;height:36px;border-radius:8px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;font-size:1.1rem;transition:all .3s ease}
.bic div:hover{background:rgba(255,255,255,.1);border-color:rgba(0,170,255,.3);transform:translateY(-3px)}

/* HERO LOGO */
.hrgt{display:flex;align-items:center;justify-content:center}
.hlw{position:relative;width:320px;height:320px;display:flex;align-items:center;justify-content:center}
.hrng{position:absolute;border-radius:50%;border:2px solid transparent;animation:spin linear infinite}
.r1{inset:0;border-color:rgba(0,170,255,.5) transparent rgba(0,170,255,.5) transparent;animation-duration:8s}
.r2{inset:20px;border-color:transparent rgba(0,255,247,.4) transparent rgba(0,255,247,.4);animation-duration:12s;animation-direction:reverse}
.r3{inset:40px;border-color:rgba(123,47,255,.3) transparent rgba(123,47,255,.3) transparent;animation-duration:16s}
.hli{position:relative;z-index:2;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;background:radial-gradient(circle,rgba(0,80,180,.18) 0%,rgba(0,0,0,.55) 100%);border-radius:50%;width:210px;height:210px;border:2px solid rgba(0,170,255,.3);box-shadow:0 0 60px rgba(0,170,255,.28),inset 0 0 60px rgba(0,170,255,.05);animation:flt 4s ease-in-out infinite}
.hll{font-family:var(--fd);font-size:3.2rem;font-weight:900;color:#fff;text-shadow:0 0 30px rgba(0,170,255,.9);line-height:1}
.hln{font-family:var(--fd);font-size:.82rem;font-weight:700;color:#fff;letter-spacing:.1em;margin-top:.5rem}
.hln span{color:var(--blue)}
.hlt{font-family:var(--fh);font-size:.52rem;letter-spacing:.15em;text-transform:uppercase;color:var(--text);margin-top:.2rem}

/* STATS BAR */
.sb{background:rgba(7,13,20,.92);border-top:1px solid rgba(0,170,255,.1);border-bottom:1px solid rgba(0,170,255,.1);padding:1.5rem 2rem;position:relative;z-index:2}
.sbi{max-width:1000px;margin:0 auto;display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;text-align:center}
.snum{font-family:var(--fd);font-size:1.9rem;font-weight:900;color:var(--blue);text-shadow:var(--gb);display:block;line-height:1;margin-bottom:.3rem}
.stxt{font-family:var(--fh);font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--text)}

/* SECTIONS */
section{padding:5rem 2rem;position:relative;z-index:1}
.si{max-width:1280px;margin:0 auto}
.stg{font-family:var(--fh);font-size:.72rem;letter-spacing:.2em;text-transform:uppercase;color:var(--blue);font-weight:700;display:block;text-align:center;margin-bottom:.5rem}
.sti{font-family:var(--fd);font-size:clamp(1.7rem,3.2vw,2.7rem);font-weight:900;color:#fff;text-align:center;margin-bottom:.75rem}
.sti span{color:var(--blue)}
.sln{width:55px;height:3px;background:linear-gradient(90deg,var(--blue),var(--cyan));margin:0 auto 3rem;border-radius:2px;box-shadow:var(--gb)}
.gd{height:1px;background:linear-gradient(90deg,transparent,rgba(0,170,255,.35),transparent)}

/* SERVICES */
#services{background:linear-gradient(180deg,var(--black) 0%,var(--dark) 100%)}
.sg{display:grid;grid-template-columns:repeat(5,1fr);gap:1.2rem}
.sc2{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:1.5rem 1.2rem;display:flex;flex-direction:column;align-items:center;gap:.9rem;text-align:center;transition:all .4s cubic-bezier(.4,0,.2,1);cursor:pointer;position:relative;overflow:hidden}
.sc2::before{content:'';position:absolute;inset:0;background:var(--cg,transparent);opacity:0;transition:opacity .4s ease;border-radius:16px}
.sc2:hover::before{opacity:1}
.sc2:hover{transform:translateY(-8px) scale(1.02);border-color:var(--cc,rgba(0,170,255,.4));box-shadow:0 20px 50px rgba(0,0,0,.5),0 0 40px var(--cs,rgba(0,170,255,.2))}
.sc2.ff{--cc:rgba(255,165,0,.4);--cs:rgba(255,165,0,.2);--cg:radial-gradient(circle at center,rgba(255,165,0,.05) 0%,transparent 70%)}
.sc2.st{--cc:rgba(255,45,120,.4);--cs:rgba(255,45,120,.2);--cg:radial-gradient(circle at center,rgba(255,45,120,.05) 0%,transparent 70%)}
.sc2.mu{--cc:rgba(147,51,234,.4);--cs:rgba(147,51,234,.2);--cg:radial-gradient(circle at center,rgba(147,51,234,.05) 0%,transparent 70%)}
.sc2.ca{--cc:rgba(0,255,247,.4);--cs:rgba(0,255,247,.2);--cg:radial-gradient(circle at center,rgba(0,255,247,.05) 0%,transparent 70%)}
.sc2.re{--cc:rgba(0,255,136,.4);--cs:rgba(0,255,136,.2);--cg:radial-gradient(circle at center,rgba(0,255,136,.05) 0%,transparent 70%)}
.ce{font-size:2.5rem}.cn{font-family:var(--fh);font-size:1rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase}
.sc2.ff .cn{color:#ffa500}.sc2.st .cn{color:var(--pink)}.sc2.mu .cn{color:#9b59b6}.sc2.ca .cn{color:var(--cyan)}.sc2.re .cn{color:var(--green)}
.cd{font-size:.77rem;color:var(--text);line-height:1.55}
.cb{display:inline-flex;align-items:center;gap:.4rem;padding:.5rem 1rem;border-radius:8px;font-family:var(--fh);font-size:.72rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;border:1px solid currentColor;transition:all .3s ease;margin-top:auto}
.sc2.ff .cb{color:#ffa500}.sc2.st .cb{color:var(--pink)}.sc2.mu .cb{color:#9b59b6}.sc2.ca .cb{color:var(--cyan)}.sc2.re .cb{color:var(--green)}
.sc2:hover .cb{background:rgba(255,255,255,.07)}

/* AVANTAGES */
#av{background:var(--dark)}
.ag{display:grid;grid-template-columns:repeat(5,1fr);gap:1.4rem}
.ac{display:flex;flex-direction:column;align-items:center;gap:.9rem;text-align:center;padding:2rem 1rem;border-radius:16px;background:rgba(255,255,255,.02);border:1px solid rgba(255,255,255,.06);transition:all .4s ease}
.ac:hover{background:rgba(255,255,255,.04);border-color:rgba(0,170,255,.18);transform:translateY(-5px)}
.ai{width:70px;height:70px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.9rem;transition:all .3s ease}
.ac:hover .ai{transform:scale(1.1)}
.ai.ib{background:rgba(0,170,255,.1);border:2px solid rgba(0,170,255,.3);box-shadow:0 0 20px rgba(0,170,255,.15)}
.ai.ip{background:rgba(255,45,120,.1);border:2px solid rgba(255,45,120,.3);box-shadow:0 0 20px rgba(255,45,120,.15)}
.ai.ig{background:rgba(255,215,0,.1);border:2px solid rgba(255,215,0,.3);box-shadow:0 0 20px rgba(255,215,0,.15)}
.ai.igr{background:rgba(0,255,136,.1);border:2px solid rgba(0,255,136,.3);box-shadow:0 0 20px rgba(0,255,136,.15)}
.ai.iv{background:rgba(123,47,255,.1);border:2px solid rgba(123,47,255,.3);box-shadow:0 0 20px rgba(123,47,255,.15)}
.at{font-family:var(--fh);font-size:.88rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase}
.ac:nth-child(1) .at{color:var(--blue)}.ac:nth-child(2) .at{color:var(--pink)}.ac:nth-child(3) .at{color:var(--gold)}.ac:nth-child(4) .at{color:var(--green)}.ac:nth-child(5) .at{color:var(--violet)}
.ade{font-size:.78rem;color:var(--text);line-height:1.55}

/* AVIS */
#avis{background:var(--black)}
.asl{position:relative;overflow:hidden}
.atr{display:flex;gap:1.4rem;animation:savis 32s linear infinite;width:max-content}
.atr:hover{animation-play-state:paused}
@keyframes savis{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.avc{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:1.4rem;min-width:270px;max-width:270px;flex-shrink:0;transition:all .3s ease}
.avc:hover{border-color:rgba(0,170,255,.28);background:rgba(255,255,255,.05);box-shadow:0 10px 40px rgba(0,0,0,.4)}
.ato{display:flex;align-items:center;gap:.7rem;margin-bottom:.9rem}
.aav{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--violet));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.95rem;color:#fff;border:2px solid rgba(0,170,255,.3);flex-shrink:0}
.anm{font-family:var(--fh);font-size:.88rem;font-weight:700;color:#fff;display:flex;align-items:center;gap:.4rem}
.vb{font-size:.62rem;background:rgba(0,255,136,.12);border:1px solid rgba(0,255,136,.3);color:var(--green);padding:.1rem .4rem;border-radius:100px}
.ast{color:var(--gold);font-size:.85rem}
.atx{font-size:.8rem;color:var(--text);line-height:1.6}
.asrv{margin-top:.7rem;display:inline-block;font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;color:var(--blue);background:rgba(0,170,255,.1);border:1px solid rgba(0,170,255,.2);padding:.18rem .55rem;border-radius:100px}
.asl::before,.asl::after{content:'';position:absolute;top:0;bottom:0;width:80px;z-index:2;pointer-events:none}
.asl::before{left:0;background:linear-gradient(90deg,var(--black),transparent)}
.asl::after{right:0;background:linear-gradient(-90deg,var(--black),transparent)}

/* COMMUNAUTE */
#com{background:var(--dark)}
.cg2{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
.cc2{border-radius:20px;padding:2.5rem 2rem;display:flex;flex-direction:column;align-items:center;gap:1.2rem;text-align:center;position:relative;overflow:hidden;transition:all .4s ease;cursor:pointer}
.cc2::before{content:'';position:absolute;inset:0;opacity:.08;transition:opacity .4s ease}
.cc2:hover{transform:translateY(-8px)}.cc2:hover::before{opacity:.15}
.cc2.tg{background:rgba(0,136,204,.08);border:1px solid rgba(0,136,204,.3)}
.cc2.tg::before{background:var(--blue)}.cc2.tg:hover{box-shadow:0 20px 60px rgba(0,136,204,.28);border-color:var(--blue)}
.cc2.tk{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.1)}
.cc2.tk::before{background:linear-gradient(135deg,#ff0050,#00f2ea)}.cc2.tk:hover{box-shadow:0 20px 60px rgba(0,242,234,.18);border-color:rgba(0,242,234,.4)}
.cc2.sn{background:rgba(255,252,0,.04);border:1px solid rgba(255,252,0,.2)}
.cc2.sn::before{background:#fffc00}.cc2.sn:hover{box-shadow:0 20px 60px rgba(255,252,0,.18);border-color:rgba(255,252,0,.4)}
.clg{font-size:3.5rem;line-height:1}
.cnm{font-family:var(--fd);font-size:1.3rem;font-weight:900;color:#fff;letter-spacing:.05em}
.cds{font-size:.83rem;color:var(--text);line-height:1.6}
.cst{font-family:var(--fh);font-size:.78rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.3rem 1rem;border-radius:100px}
.tg .cst{color:var(--blue);background:rgba(0,136,204,.1);border:1px solid rgba(0,136,204,.3)}
.tk .cst{color:#00f2ea;background:rgba(0,242,234,.1);border:1px solid rgba(0,242,234,.3)}
.sn .cst{color:#fffc00;background:rgba(255,252,0,.1);border:1px solid rgba(255,252,0,.3)}
.cbtn3{display:inline-flex;align-items:center;gap:.5rem;padding:.8rem 2rem;border-radius:10px;font-family:var(--fh);font-size:.88rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;transition:all .3s ease;width:100%;justify-content:center}
.tg .cbtn3{background:var(--blue);color:#fff;box-shadow:0 4px 20px rgba(0,136,204,.4)}
.tg .cbtn3:hover{box-shadow:0 8px 30px rgba(0,136,204,.6);transform:translateY(-2px)}
.tk .cbtn3{background:linear-gradient(135deg,#ff0050,#00f2ea);color:#fff}
.tk .cbtn3:hover{box-shadow:0 8px 30px rgba(255,0,80,.4);transform:translateY(-2px)}
.sn .cbtn3{background:#fffc00;color:#000}
.sn .cbtn3:hover{box-shadow:0 8px 30px rgba(255,252,0,.4);transform:translateY(-2px)}

/* FAQ */
#faq{background:var(--black)}
.fl{max-width:800px;margin:0 auto;display:flex;flex-direction:column;gap:.7rem}
.fi{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:12px;overflow:hidden;transition:border-color .3s ease}
.fi.open{border-color:rgba(0,170,255,.3)}
.fq2{display:flex;align-items:center;justify-content:space-between;padding:1.2rem 1.5rem;cursor:pointer;font-family:var(--fh);font-size:.98rem;font-weight:600;color:#fff;user-select:none;transition:color .2s ease}
.fq2:hover{color:var(--blue)}.fi.open .fq2{color:var(--blue)}
.fic{font-size:1.1rem;color:var(--blue);transition:transform .3s ease;flex-shrink:0}
.fi.open .fic{transform:rotate(45deg)}
.fa{max-height:0;overflow:hidden;transition:max-height .4s ease,padding .3s ease;font-size:.85rem;color:var(--text);line-height:1.7;padding:0 1.5rem}
.fi.open .fa{max-height:300px;padding:0 1.5rem 1.2rem}

/* FOOTER */
footer{background:var(--dark);border-top:1px solid rgba(255,255,255,.06);padding:3rem 2rem 1.5rem;position:relative;z-index:1}
.fi2{max-width:1280px;margin:0 auto}
.fg{display:grid;grid-template-columns:2fr 1fr 1fr 1.5fr;gap:2.5rem;margin-bottom:2.5rem}
.flg{display:flex;align-items:center;gap:.7rem;margin-bottom:.9rem}
.fli{width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,var(--blue),var(--violet));display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-weight:900;font-size:.82rem;color:#fff;box-shadow:var(--gb)}
.flt{font-family:var(--fd);font-size:.95rem;font-weight:700;color:#fff}.flt span{color:var(--blue)}
.fds{font-size:.8rem;color:var(--text);line-height:1.7;margin-bottom:1.2rem}
.fsc{display:flex;gap:.7rem}
.fsi{width:34px;height:34px;border-radius:8px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);display:flex;align-items:center;justify-content:center;font-size:1.05rem;transition:all .3s ease}
.fsi:hover{background:rgba(0,170,255,.1);border-color:var(--blue);transform:translateY(-3px)}
.fct{font-family:var(--fh);font-size:.72rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:#fff;margin-bottom:1.2rem}
.fc2 ul{display:flex;flex-direction:column;gap:.55rem}.fc2 ul a{font-size:.8rem;color:var(--text);transition:color .2s ease;display:block}
.fc2 ul a:hover{color:var(--blue)}
.fcn{display:flex;flex-direction:column;gap:.7rem}
.cbt{display:inline-flex;align-items:center;gap:.5rem;padding:.7rem 1.2rem;border-radius:10px;font-family:var(--fh);font-size:.8rem;font-weight:700;letter-spacing:.05em;text-transform:uppercase;transition:all .3s ease}
.cbt.wa{background:rgba(37,211,102,.12);border:1px solid rgba(37,211,102,.35);color:#25d366}
.cbt.wa:hover{background:rgba(37,211,102,.22);box-shadow:0 4px 20px rgba(37,211,102,.28)}
.cbt.em{background:rgba(0,170,255,.1);border:1px solid rgba(0,170,255,.3);color:var(--blue)}
.cbt.em:hover{background:rgba(0,170,255,.2);box-shadow:var(--gb)}
.fb2{border-top:1px solid rgba(255,255,255,.06);padding-top:1.5rem;text-align:center;font-size:.76rem;color:rgba(184,204,224,.38)}

/* FLOAT */
.fw{position:fixed;right:1.5rem;bottom:1.5rem;display:flex;flex-direction:column;gap:.7rem;z-index:500}
.fab{width:50px;height:50px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.3rem;cursor:pointer;transition:all .3s ease;border:none;text-decoration:none}
.fab:hover{transform:scale(1.1) translateY(-3px)}
.fwa{background:#25d366;box-shadow:0 4px 20px rgba(37,211,102,.5);color:#fff}
.ftp{background:rgba(0,170,255,.14);border:1px solid rgba(0,170,255,.35);color:var(--blue);box-shadow:var(--gb);opacity:0;transform:translateY(10px);transition:all .3s ease;cursor:pointer;font-size:1.1rem;font-weight:700}
.ftp.vis{opacity:1;transform:translateY(0)}.ftp:hover{background:rgba(0,170,255,.28)}

/* RESPONSIVE */
@media(max-width:1100px){.sg{grid-template-columns:repeat(3,1fr)}.ag{grid-template-columns:repeat(3,1fr)}.fg{grid-template-columns:1fr 1fr}}
@media(max-width:900px){.hi{grid-template-columns:1fr;text-align:center}.hrgt{display:none}.hbdg,.hbts,.hbr{justify-content:center;margin-left:auto;margin-right:auto}.hbts{flex-direction:column;max-width:350px;margin-left:auto;margin-right:auto}.hst{grid-template-columns:repeat(2,1fr)}.sbi{grid-template-columns:repeat(2,1fr)}.cg2{grid-template-columns:1fr;max-width:500px;margin:0 auto}}
@media(max-width:768px){.nlinks{display:none}.brg{display:flex}section{padding:3.5rem 1.25rem}.sg{grid-template-columns:repeat(2,1fr)}.ag{grid-template-columns:repeat(2,1fr)}.fg{grid-template-columns:1fr;gap:2rem}}
@media(max-width:480px){.sg{grid-template-columns:1fr}.ag{grid-template-columns:1fr}.hst{grid-template-columns:repeat(2,1fr)}.sbi{grid-template-columns:repeat(2,1fr)}.bp,.bt{width:100%;justify-content:center}}
</style>
</head>
