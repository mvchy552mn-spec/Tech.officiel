<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tech Officiel</title>

<style>

body{
margin:0;
background:#050816;
font-family:Arial;
color:white;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
overflow:hidden;
}

.box{
text-align:center;
padding:40px;
border-radius:20px;
background:#0f172a;
border:1px solid #00aaff55;
box-shadow:0 0 40px #00aaff33;
}

h1{
font-size:50px;
margin:0;
color:#00aaff;
}

p{
opacity:.8;
margin-top:15px;
font-size:20px;
}

a{
display:inline-block;
margin-top:25px;
padding:15px 30px;
border-radius:12px;
background:linear-gradient(135deg,#00aaff,#0066ff);
text-decoration:none;
color:white;
font-weight:bold;
}

</style>
</head>

<body>

<div class="box">

<h1>TECH.OFFICIEL</h1>

<p>
SITE EN LIGNE ✅
</p>

<a href="https://t.me/TONTELEGRAM">
COMMANDER
</a>

</div>

</body>
</html>
