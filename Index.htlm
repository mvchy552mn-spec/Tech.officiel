<script>
// LOADER
window.addEventListener('load',()=>setTimeout(()=>document.getElementById('loader').classList.add('hidden'),2400))

// NAV SCROLL
const nav=document.getElementById('nav')
window.addEventListener('scroll',()=>{
  nav.classList.toggle('sc',window.scrollY>50)
  document.getElementById('btop').classList.toggle('vis',window.scrollY>400)
})

// BURGER
function toggleMenu(){document.getElementById('brg').classList.toggle('open');document.getElementById('mm').classList.toggle('open')}
function closeMenu(){document.getElementById('brg').classList.remove('open');document.getElementById('mm').classList.remove('open')}

// BACK TOP
document.getElementById('btop').addEventListener('click',()=>window.scrollTo({top:0,behavior:'smooth'}))

// REVEAL
const obs=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('vis')}),{threshold:.12})
document.querySelectorAll('.rv').forEach(el=>obs.observe(el))

// COUNTER
function animCount(el){
  const t=parseInt(el.dataset.target);if(!t)return
  let st=null,d=t/60
  function step(ts){
    if(!st)st=ts
    const s=Math.min(t,Math.floor(d*(ts-st)/16))
    el.textContent=s>=1000?'+'+(s/1000).toFixed(0)+'K':s
    if(s<t)requestAnimationFrame(step)
    else el.textContent=t>=1000?'+'+(t/1000).toFixed(0)+'K':t
  }
  requestAnimationFrame(step)
}
const cObs=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting&&!x.target.dataset.done){x.target.dataset.done='1';animCount(x.target)}}),{threshold:.5})
document.querySelectorAll('.snum[data-target]').forEach(el=>cObs.observe(el))

// PARTICLES
const canvas=document.getElementById('pc'),ctx=canvas.getContext('2d')
let W,H,pts=[]
function resize(){W=canvas.width=window.innerWidth;H=canvas.height=window.innerHeight;pts=[];const n=Math.min(80,Math.floor(W*H/12000));for(let i=0;i<n;i++)pts.push({x:Math.random()*W,y:Math.random()*H,vx:(Math.random()-.5)*.3,vy:(Math.random()-.5)*.3,r:Math.random()*1.5+.5,a:Math.random()})}
function draw(){
  ctx.clearRect(0,0,W,H)
  pts.forEach(p=>{p.x+=p.vx;p.y+=p.vy;if(p.x<0||p.x>W)p.vx*=-1;if(p.y<0||p.y>H)p.vy*=-1;ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fillStyle=`rgba(0,170,255,${p.a*.6})`;ctx.fill()})
  pts.forEach((a,i)=>{for(let j=i+1;j<pts.length;j++){const b=pts[j],dx=a.x-b.x,dy=a.y-b.y,d=Math.sqrt(dx*dx+dy*dy);if(d<120){ctx.beginPath();ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);ctx.strokeStyle=`rgba(0,170,255,${(1-d/120)*.1})`;ctx.lineWidth=.5;ctx.stroke()}}})
  requestAnimationFrame(draw)
}
window.addEventListener('resize',resize);resize();draw()

// AVIS
const avisData=[
  {n:'Yanis.92',i:'Y',s:5,t:'Service incroyable, rapide et fiable ! Je recommande à 100% 🔥',sv:'Fast Food',c:'#ff6b35'},
  {n:'Sarah_1',i:'S',s:5,t:"J'ai reçu mon code Netflix en 2 minutes, parfait ! Merci à l'équipe 🙌",sv:'Streaming',c:'#e50914'},
  {n:'Mehdi103',i:'M',s:5,t:'Meilleurs prix du marché et support ultra réactif ! Franchement au top 💪',sv:'Cartes',c:'#00aaff'},
  {n:'Kenza.off',i:'K',s:5,t:'Spotify premium reçu instantanément. Prix imbattables, je reviens !',sv:'Musique',c:'#1db954'},
  {n:'Rayan2k',i:'R',s:5,t:"Commande O'Tacos remboursée en 3 minutes chrono. Incroyable !",sv:'Fast Food',c:'#ff6b35'},
  {n:'Lina_bx',i:'L',s:5,t:'Disney+ pour toute la famille à prix mini. Équipe au top, merci !',sv:'Streaming',c:'#113ccf'},
  {n:'Omar.h',i:'O',s:5,t:'Carte PSN reçue instantanément. Super service, je recommande 🎮',sv:'Cartes',c:'#00aaff'},
  {n:'Imane99',i:'I',s:5,t:'Support disponible le soir aussi ! Vraiment sérieux et professionnel.',sv:'Support',c:'#7b2fff'},
  {n:'Karim.off',i:'K',s:5,t:'3ème commande et toujours aussi satisfait. Fiabilité au rendez-vous !',sv:'Fast Food',c:'#ff6b35'},
  {n:'Nadia_l',i:'N',s:5,t:'YouTube Premium activé en moins de 5 minutes. Parfait 👌',sv:'Musique',c:'#ff0000'},
  {n:'Amine95',i:'A',s:5,t:'Amazon Prime livré en 1 minute. Ce shop est légendaire 🏆',sv:'Streaming',c:'#00a8e0'},
  {n:'Fatou.k',i:'F',s:5,t:'Cagnotte reçue sans souci. Très pro et rapide. Merci beaucoup !',sv:'Cagnottes',c:'#7b2fff'},
]
const doubled=[...avisData,...avisData]
document.getElementById('atr').innerHTML=doubled.map(a=>`<div class="avc"><div class="ato"><div class="aav" style="background:linear-gradient(135deg,${a.c},#7b2fff)">${a.i}</div><div><div class="anm">${a.n}<span class="vb">✓ Vérifié</span></div><div class="ast">${'★'.repeat(a.s)}</div></div></div><div class="atx">${a.t}</div><span class="asrv">${a.sv}</span></div>`).join('')

// FAQ
const faqData=[
  {q:'Comment passer une commande ?',a:"Contactez-nous directement via Telegram ou WhatsApp. Notre équipe vous guidera et livrera votre commande en quelques minutes seulement."},
  {q:'Quels modes de paiement acceptez-vous ?',a:"Nous acceptons PayPal, virement bancaire, et plusieurs autres méthodes sécurisées. Contactez-nous pour plus de détails selon votre situation."},
  {q:'Combien de temps pour recevoir ma commande ?',a:"La majorité de nos commandes sont livrées en 5 à 15 minutes. Pour certains articles spécifiques, le délai peut aller jusqu'à 30 minutes maximum."},
  {q:'Est-ce que vos services sont fiables ?',a:"Absolument ! Nous garantissons la qualité et le bon fonctionnement de tous nos services. Plus de 12 000 clients satisfaits en témoignent."},
  {q:'Que faire si je rencontre un problème ?',a:"Notre support est disponible 24h/24 et 7j/7 via Telegram et WhatsApp. Nous résolvons tous les problèmes dans les plus brefs délais, satisfaction garantie."},
  {q:'Proposez-vous des offres groupées ?',a:"Oui ! Nous proposons des packs et tarifs dégressifs pour les commandes multiples. Contactez-nous pour une offre personnalisée selon vos besoins."},
]
document.getElementById('fl').innerHTML=faqData.map((f,i)=>`<div class="fi rv" style="transition-delay:${i*.06}s"><div class="fq2" onclick="toggleFaq(this)"><span>${f.q}</span><span class="fic">+</span></div><div class="fa">${f.a}</div></div>`).join('')
document.querySelectorAll('.fi.rv').forEach(el=>obs.observe(el))
function toggleFaq(el){
  const it=el.parentElement,was=it.classList.contains('open')
  document.querySelectorAll('.fi.open').forEach(f=>f.classList.remove('open'))
  if(!was)it.classList.add('open')
}
</script>
</body>
</html>
